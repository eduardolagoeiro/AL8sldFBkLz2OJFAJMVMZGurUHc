{
  "name": "starter-kit-expo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "expo start --port 8082",
    "android": "expo start --port 8082 --android",
    "ios": "expo start --port 8082 --ios",
    "web": "expo start --port 8082 --web",
    "build": "expo export --platform web --output-dir dist",
    "build:preview": "expo export --platform web --output-dir dist",
    "test": "jest --watchAll"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/html-elements": "^0.12.5",
    "@expo/vector-icons": "^15.0.2",
    "@gluestack-ui/core": "^3.0.12",
    "@gluestack-ui/utils": "^3.0.13",
    "@gorhom/bottom-sheet": "^5.0.0-alpha.11",
    "@legendapp/motion": "^2.4.0",
    "@react-aria/utils": "^3.29.0",
    "@react-navigation/native": "^7.1.6",
    "babel-plugin-module-resolver": "^5.0.2",
    "dom-helpers": "^5.2.1",
    "expo": "^54.0.7",
    "expo-font": "~14.0.8",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.4",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.7",
    "lucide-react-native": "^0.510.0",
    "react-native-url-polyfill": "^2.0.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-aria": "^3.41.1",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-stately": "^3.39.0",
    "tailwind-variants": "^0.1.20",
    "zod": "^4.3.0",
    "zustand": "^5.0.11",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "fast-text-encoding": "^1.0.6",
    "msw": "2.4.11",
    "@types/react": "~19.1.10",
    "eslint": "^9.18.0",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.11",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": "prettier --write"
  },
  "volta": {
    "node": "24.14.0",
    "yarn": "1.22.22"
  }
}
